<Location /svn>
    DAV svn
    SVNParentPath /var/svn/repos
    SVNListParentPath on
    
    AuthType Basic
    AuthName "SVN Repository"

    AuthBasicProvider ldap
    AuthLDAPURL "${LDAP_AUTH_URL}"
    AuthLDAPBindDN "${LDAP_BIND_DN}"
    AuthLDAPBindPassword "${LDAP_BIND_PASSWORD}"

    Require valid-user
</Location>

